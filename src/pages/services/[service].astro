---
import Layout from '../../layouts/Layout.astro';
import WizardForm from '../../components/WizardForm';
import FAQSection from '../../components/FAQSection.astro';
import { SERVICES } from '../../data/services';
import { VILLES } from '../../data/villes';

export async function getStaticPaths() {
  return SERVICES.map(service => ({
    params: { service: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props;
const siteUrl = 'https://d4-conversion-demo.netlify.app';

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.name,
  "description": service.description,
  "provider": {
    "@type": "LocalBusiness",
    "name": "MaxNuisibles",
    "telephone": "+33800000000",
    "url": siteUrl,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "847"
    }
  },
  "areaServed": "Sud de la France",
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "EUR",
      "description": service.price
    }
  }
};
---

<Layout
  title={`${service.name} | MaxNuisibles — 0 800 000 000 — Intervention 2h`}
  description={`${service.name} professionnel dans le Sud de la France. ${service.guarantee}. Techniciens agréés. Devis gratuit au 0 800 000 000. Intervention en moins de 2h.`}
  schema={schemaService}
>
  <!-- Hero service -->
  <section class="relative bg-[#0a0f1e] py-16 sm:py-24 overflow-hidden" aria-labelledby="service-heading">
    <div class="absolute inset-0" aria-hidden="true">
      <img
        src={service.image}
        alt=""
        class="w-full h-full object-cover opacity-20"
        loading="eager"
      />
      <div class="absolute inset-0" style="background:linear-gradient(135deg,rgba(10,15,30,0.95),rgba(0,102,255,0.7))"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-5 gap-10 items-center">
        <div class="lg:col-span-3">
          <div class="inline-flex items-center gap-2 bg-[#10b981]/20 border border-[#10b981]/40 text-[#10b981] font-bold text-sm px-4 py-2 rounded-full mb-6">
            <span class="pulse-dot w-2 h-2 rounded-full bg-[#10b981] block"></span>
            {service.guarantee} · Intervention -2h
          </div>
          <h1 id="service-heading" class="text-4xl sm:text-5xl font-black text-white leading-tight mb-4">
            {service.icon} {service.headline}
          </h1>
          <p class="text-white/80 text-lg mb-6">{service.description}</p>
          <div class="flex flex-wrap gap-3 mb-8">
            {['✓ Agréé assurance', `✓ ${service.guarantee}`, '✓ Devis gratuit', '✓ Intervention -2h'].map(p => (
              <span class="bg-white/10 text-white text-sm font-semibold px-3 py-1.5 rounded-full">{p}</span>
            ))}
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="tel:+33800000000"
              class="gradient-cta glow-cta text-white font-black text-lg px-8 py-4 rounded-xl flex items-center justify-center gap-2"
              style="background:linear-gradient(135deg,#00e5ff,#0066ff)"
            >
              📞 0 800 000 000
            </a>
            <div class="flex items-center gap-2 text-white/70 text-sm">
              <span class="text-yellow-400">★★★★★</span>
              <span>4.9/5 · 847 avis · Numéro gratuit</span>
            </div>
          </div>
        </div>
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl p-6 shadow-2xl">
            <h2 class="text-lg font-black text-[#0a0f1e] text-center mb-4">Devis gratuit — 15 min</h2>
            <WizardForm client:load />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution section -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-black text-[#0a0f1e] mb-4">Le problème</h2>
          <div class="bg-red-50 border border-red-100 rounded-2xl p-5 mb-6">
            <p class="text-red-700 font-semibold">⚠️ {service.problem}</p>
          </div>
          <h2 class="text-3xl font-black text-[#0a0f1e] mb-4">Notre solution</h2>
          <div class="bg-[#10b981]/10 border border-[#10b981]/20 rounded-2xl p-5">
            <p class="text-[#10b981] font-semibold">✅ {service.solution}</p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-xl">
          <img
            src={service.image}
            alt={service.name}
            width="600"
            height="400"
            class="w-full object-cover"
            style="aspect-ratio:3/2"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Price & Trust -->
  <section class="py-16 bg-[#f8fafc]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid sm:grid-cols-3 gap-6">
        {[
          { icon: '💰', title: 'Tarif', value: service.price, sub: 'Devis gratuit avant intervention' },
          { icon: '🛡️', title: 'Garantie', value: service.guarantee, sub: 'Retour gratuit si réapparition' },
          { icon: '⏱️', title: 'Délai', value: 'Moins de 2h', sub: 'Disponible 24h/24 · 7j/7' },
        ].map(item => (
          <div class="bg-white rounded-2xl p-6 text-center shadow-sm border border-gray-100">
            <div class="text-3xl mb-3">{item.icon}</div>
            <div class="text-gray-500 text-sm uppercase tracking-wide font-semibold mb-1">{item.title}</div>
            <div class="font-black text-2xl text-[#0066ff] mb-1">{item.value}</div>
            <div class="text-gray-500 text-xs">{item.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Villes disponibles -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-black text-[#0a0f1e] mb-6 text-center">
        {service.name} disponible dans 20 villes
      </h2>
      <div class="grid grid-cols-3 sm:grid-cols-5 gap-2">
        {VILLES.map(ville => (
          <a
            href={`/${ville.slug}/${service.slug}`}
            class="bg-[#f8fafc] hover:bg-[#0066ff]/5 border border-gray-200 hover:border-[#0066ff]/30 rounded-xl p-3 text-center text-xs font-semibold text-[#0a0f1e] hover:text-[#0066ff] transition-all"
          >
            {ville.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ spécifique service -->
  <FAQSection
    title={`FAQ — ${service.name}`}
    items={service.faq}
  />

  <!-- CTA final -->
  <section class="py-16" style="background:linear-gradient(135deg,#0a0f1e,#0066ff)">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-black text-white mb-4">
        Intervention {service.name} en moins de 2h
      </h2>
      <a
        href="tel:+33800000000"
        class="inline-flex items-center gap-3 bg-white text-[#0066ff] font-black text-xl px-10 py-5 rounded-2xl shadow-2xl hover:scale-105 transition-transform"
      >
        📞 0 800 000 000 — Appel gratuit
      </a>
      <p class="text-white/60 text-sm mt-4">{service.guarantee} · Devis gratuit · Disponible maintenant</p>
    </div>
  </section>
</Layout>
