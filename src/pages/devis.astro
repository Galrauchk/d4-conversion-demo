---
import Layout from '../layouts/Layout.astro';
import WizardForm from '../components/WizardForm';
---

<Layout
  title="Devis gratuit | MaxNuisibles — Réponse en 15 min"
  description="Demandez votre devis gratuit en ligne pour traitement nuisibles. Réponse en 15 minutes. Intervention garantie en moins de 2h. Agréé assurance."
>
  <section class="min-h-[calc(100vh-88px)] flex items-center bg-[#f8fafc] py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 w-full">
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 bg-[#10b981]/10 border border-[#10b981]/30 text-[#10b981] font-bold text-sm px-4 py-2 rounded-full mb-6">
          <span class="pulse-dot w-2.5 h-2.5 rounded-full bg-[#10b981] block"></span>
          Disponible MAINTENANT · Réponse en 15 min
        </div>
        <h1 class="text-4xl font-black text-[#0a0f1e] mb-3">
          Votre devis gratuit
        </h1>
        <p class="text-gray-600 text-lg">
          Remplissez le formulaire en 2 minutes.<br />
          Un technicien vous rappelle dans les 15 minutes.
        </p>
      </div>

      <div class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-8" style="box-shadow:0 25px 50px rgba(0,0,0,0.1)">
        <WizardForm client:load />
        <div class="mt-6 pt-6 border-t border-gray-100">
          <p class="text-center text-gray-400 text-sm mb-4">Ou appelez directement :</p>
          <a
            href="tel:+33800000000"
            class="gradient-cta glow-cta text-white font-black text-xl px-8 py-5 rounded-xl flex items-center justify-center gap-3 w-full"
            style="background:linear-gradient(135deg,#00e5ff,#0066ff)"
          >
            📞 0 800 000 000
            <span class="text-sm font-normal opacity-80">Numéro gratuit</span>
          </a>
        </div>
      </div>

      <!-- Trust signals -->
      <div class="grid grid-cols-3 gap-4 mt-8">
        {[
          { icon: '🔒', label: 'Données protégées' },
          { icon: '🎯', label: 'Sans engagement' },
          { icon: '⚡', label: 'Réponse 15 min' },
        ].map(t => (
          <div class="text-center">
            <div class="text-2xl mb-1">{t.icon}</div>
            <p class="text-gray-600 text-xs font-medium">{t.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
