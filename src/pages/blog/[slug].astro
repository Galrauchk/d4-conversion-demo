---
import Layout from '../../layouts/Layout.astro';
import { BLOG_POSTS } from '../../data/blog';

export async function getStaticPaths() {
  return BLOG_POSTS.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const siteUrl = 'https://d4-conversion-demo.netlify.app';

const schemaArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.description,
  "datePublished": post.date,
  "author": {
    "@type": "Organization",
    "name": "MaxNuisibles"
  },
  "publisher": {
    "@type": "Organization",
    "name": "MaxNuisibles",
    "url": siteUrl
  }
};
---

<Layout
  title={`${post.title} | Blog MaxNuisibles`}
  description={post.description}
  schema={schemaArticle}
>
  <!-- Hero article -->
  <section class="py-12 bg-[#0a0f1e]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white">Accueil</a>
        <span>›</span>
        <a href="/blog" class="hover:text-white">Blog</a>
        <span>›</span>
        <span class="text-white truncate max-w-xs">{post.title}</span>
      </nav>
      <div class="flex items-center gap-3 mb-4">
        <span class="bg-[#00e5ff]/20 text-[#00e5ff] font-bold text-xs px-3 py-1 rounded-full">{post.category}</span>
        <time class="text-gray-400 text-xs" datetime={post.date}>
          {new Date(post.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        <span class="text-gray-500 text-xs">{post.readTime} de lecture</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-black text-white leading-tight">{post.title}</h1>
    </div>
  </section>

  <!-- Article content -->
  <section class="py-12 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-3 gap-10">
        <!-- Article body -->
        <article class="lg:col-span-2 prose prose-lg max-w-none">
          <p class="text-xl text-gray-600 leading-relaxed mb-8 font-medium border-l-4 border-[#0066ff] pl-4">
            {post.description}
          </p>
          <div
            class="text-gray-700 leading-relaxed [&>h2]:text-2xl [&>h2]:font-black [&>h2]:text-[#0a0f1e] [&>h2]:mt-8 [&>h2]:mb-4 [&>h3]:text-xl [&>h3]:font-bold [&>h3]:text-[#0a0f1e] [&>h3]:mt-6 [&>h3]:mb-3 [&>p]:mb-4 [&>ul]:mb-4 [&>ul]:space-y-2 [&>ul>li]:flex [&>ul>li]:gap-2 [&>strong]:font-bold [&>strong]:text-[#0a0f1e]"
            set:html={post.content}
          />
        </article>

        <!-- Sidebar CTA -->
        <aside class="lg:col-span-1">
          <div class="sticky top-24 space-y-4">
            <div class="bg-[#0a0f1e] rounded-2xl p-6 text-center">
              <div class="pulse-dot w-3 h-3 rounded-full bg-[#10b981] mx-auto mb-3"></div>
              <h3 class="text-white font-black text-lg mb-2">Nuisible détecté ?</h3>
              <p class="text-gray-400 text-sm mb-4">Intervention en moins de 2h. Devis gratuit.</p>
              <a
                href="tel:+33800000000"
                class="gradient-cta glow-cta text-white font-black text-base px-6 py-3 rounded-xl flex items-center justify-center gap-2 mb-3"
                style="background:linear-gradient(135deg,#00e5ff,#0066ff)"
              >
                📞 0 800 000 000
              </a>
              <a href="/devis" class="block text-center text-[#00e5ff] text-sm font-semibold hover:underline">
                Devis gratuit en ligne →
              </a>
            </div>

            <div class="bg-[#f8fafc] rounded-2xl p-5 border border-gray-100">
              <h4 class="font-bold text-[#0a0f1e] text-sm mb-3">Autres articles</h4>
              <div class="space-y-2">
                {BLOG_POSTS.filter(p => p.slug !== post.slug).slice(0, 3).map(p => (
                  <a href={`/blog/${p.slug}`} class="block text-xs text-gray-600 hover:text-[#0066ff] transition-colors leading-snug">
                    → {p.title}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- CTA fin d'article -->
  <section class="py-12" style="background:linear-gradient(135deg,#0a0f1e,#0066ff)">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl font-black text-white mb-4">
        Vous avez identifié le problème ? Nous avons la solution.
      </h2>
      <a
        href="tel:+33800000000"
        class="inline-flex items-center gap-2 bg-white text-[#0066ff] font-black text-lg px-8 py-4 rounded-xl hover:scale-105 transition-transform"
      >
        📞 0 800 000 000 — Intervention -2h
      </a>
    </div>
  </section>
</Layout>
