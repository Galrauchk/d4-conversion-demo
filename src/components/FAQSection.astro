---
interface FAQItem {
  q: string;
  a: string;
}
interface Props {
  items?: FAQItem[];
  title?: string;
}

const {
  title = 'Questions fréquentes',
  items = [
    {
      q: "Pourquoi ne pas choisir une entreprise moins chère ?",
      a: "Les interventions low-cost utilisent souvent des produits non homologués ou sous-dosés, sans garantie de résultat. MaxNuisibles utilise exclusivement des produits biocides agréés, appliqués par des techniciens certifiés. Résultat : un traitement efficace dès la première fois, avec garantie écrite. Le coût réel d'une infestation non traitée (santé, matériaux dégradés, stress) dépasse largement notre tarif."
    },
    {
      q: "Et si le nuisible revient après le traitement ?",
      a: "Toutes nos interventions sont garanties : 12 mois pour la dératisation, 6 mois pour les cafards, 3 mois pour les punaises de lit. Si le nuisible revient dans ce délai, nous revenons gratuitement sans discussion. C'est notre engagement qualité."
    },
    {
      q: "Intervenez-vous le week-end et les jours fériés ?",
      a: "Oui, absolument. Les nuisibles n'ont pas de jours de congé, et nous non plus. Nous sommes disponibles 7 jours sur 7, jours fériés inclus, avec le même tarif qu'en semaine pour les situations d'urgence."
    },
    {
      q: "Le 0 800 000 000 est-il vraiment gratuit ?",
      a: "Oui, c'est un numéro vert gratuit depuis n'importe quel téléphone fixe ou mobile en France. L'appel est entièrement gratuit et ne décompte aucun forfait. Nos conseillers sont disponibles de 7h à 22h, et une astreinte urgence est assurée de 22h à 7h."
    },
    {
      q: "Combien de temps dure une intervention ?",
      a: "Une intervention standard dure entre 45 minutes et 2 heures selon la superficie et le type de nuisible. Nous vous donnons une estimation précise lors du devis téléphonique. Dans la plupart des cas, vous pouvez rester chez vous pendant le traitement."
    },
    {
      q: "Acceptez-vous les paiements par carte bancaire ?",
      a: "Oui, nous acceptons les paiements par carte bancaire, virement, chèque et espèces. Pour les professionnels, nous proposons également la facturation à 30 jours. Devis gratuit avant toute intervention."
    }
  ]
} = Astro.props;

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<section class="py-20 bg-[#f8fafc]" aria-labelledby="faq-heading">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <span class="inline-block bg-[#0066ff]/10 text-[#0066ff] font-bold text-xs px-4 py-1.5 rounded-full uppercase tracking-wide mb-3">FAQ</span>
      <h2 id="faq-heading" class="text-3xl font-black text-[#0a0f1e]">{title}</h2>
    </div>

    <div class="space-y-3" id="faq-list">
      {items.map((item, i) => (
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <button
            class="faq-trigger w-full px-6 py-5 text-left flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors"
            aria-expanded="false"
            data-faq-id={`faq-${i}`}
          >
            <span class="font-semibold text-[#0a0f1e] text-sm sm:text-base">{item.q}</span>
            <svg
              class="faq-icon shrink-0 w-5 h-5 text-[#0066ff] transition-transform duration-300"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
            >
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="faq-content" id={`faq-${i}`}>
            <p class="px-6 pb-5 text-gray-600 text-sm leading-relaxed">{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

<script>
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const id = trigger.getAttribute('data-faq-id');
      const content = document.getElementById(id!);
      const icon = trigger.querySelector('.faq-icon') as SVGElement;
      const isOpen = content?.classList.contains('open');

      // Close all
      document.querySelectorAll('.faq-content').forEach(c => c.classList.remove('open'));
      document.querySelectorAll('.faq-trigger').forEach(t => {
        t.setAttribute('aria-expanded', 'false');
        (t.querySelector('.faq-icon') as SVGElement)?.style.setProperty('transform', 'rotate(0deg)');
      });

      if (!isOpen) {
        content?.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
        icon?.style.setProperty('transform', 'rotate(180deg)');
      }
    });
  });
</script>
